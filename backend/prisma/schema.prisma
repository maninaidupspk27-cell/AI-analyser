// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  fullName     String
  role         String          @default("USER") // ADMIN, SALES_MANAGER, USER
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  uploads      UploadHistory[]
  generations  Generation[]
}

model Customer {
  id               String   @id // User provided CustomerID (e.g. C001)
  customerName     String   @default("Unknown")
  totalPurchases   Float    @default(0)
  orders           Int      @default(0)
  avgOrderValue    Float    @default(0)
  paymentDelayDays Int      @default(0)
  outstanding      Float    @default(0)
  repeatRate       Float    @default(0)
  returns          Int      @default(0)
  location         String   @default("Unknown")
  
  segmentId        String?
  segment          Segment? @relation(fields: [segmentId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Segment {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String
  minRfmScore     Float
  maxRfmScore     Float
  customers       Customer[]
}



model UploadHistory {
  id           String   @id @default(uuid())
  filename     String
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  status       String   @default("PROCESSING") // PROCESSING | COMPLETED | FAILED
  totalRows    Int      @default(0)
  errorDetails String?
  createdAt    DateTime @default(now())
}

model Generation {
  id           String   @id @default(uuid())
  subject      String
  requirements String
  constraints  String
  preferences  String
  aiResponse   String
  rating       Int?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}
